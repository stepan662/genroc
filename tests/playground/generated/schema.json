{
  "process": "order-pipeline",
  "process_input": {
    "$ref": "#/$defs/input"
  },
  "process_output": {
    "$ref": "#/$defs/output"
  },
  "tasks": {
    "finish": {
      "action_type": "",
      "output": {
        "$ref": "#/$defs/finish_output"
      }
    },
    "start": {
      "action_type": "rest",
      "input": {
        "type": "integer"
      },
      "output": {
        "$ref": "#/$defs/start_output"
      }
    }
  },
  "$defs": {
    "finish_output": {
      "type": "number"
    },
    "input": {
      "type": "object",
      "properties": {
        "ttl": {
          "type": "integer"
        }
      },
      "required": [
        "ttl"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "start": {
          "type": "object",
          "properties": {
            "num": {
              "type": "number"
            },
            "str": {
              "type": "string"
            }
          },
          "required": [
            "num",
            "str"
          ]
        }
      },
      "required": [
        "start"
      ]
    },
    "start_output": {
      "type": "object",
      "properties": {
        "num": {
          "type": "number"
        },
        "str": {
          "type": "string"
        }
      },
      "required": [
        "num",
        "str"
      ]
    }
  }
}
