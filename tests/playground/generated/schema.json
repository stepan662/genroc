{
  "process": "order-pipeline",
  "process_input": {
    "$ref": "#/$defs/input"
  },
  "process_output": {
    "$ref": "#/$defs/output"
  },
  "tasks": {
    "recursion": {
      "call_type": "child",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/recursion_output"
      }
    },
    "recursion2": {
      "call_type": "child_parallel",
      "input": {
        "type": "object"
      },
      "output": {
        "$ref": "#/$defs/recursion2_output"
      }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "properties": {
        "ttl": {
          "type": "integer"
        }
      },
      "required": [
        "ttl"
      ]
    },
    "output": {
      "type": "object",
      "properties": {
        "num": {
          "type": "integer"
        }
      },
      "required": [
        "num"
      ]
    },
    "recursion2_output": {
      "type": "object",
      "properties": {
        "first": {
          "type": "object",
          "properties": {
            "num": {
              "type": "integer"
            }
          }
        },
        "second": {
          "type": "object",
          "properties": {
            "num": {
              "type": "integer"
            }
          }
        }
      },
      "required": [
        "first",
        "second"
      ]
    },
    "recursion_output": {
      "type": "object",
      "properties": {
        "num": {
          "type": "integer"
        }
      },
      "required": [
        "num"
      ]
    }
  }
}
